GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_API_VERSION=v1alpha
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_API_KEY_SID=your_twilio_account_sid_here
TWILIO_API_KEY_SECRET=your_twilio_account_sid_here
TWILIO_NUMBER=your_twilio_account_sid_here
TWILIO_PUBLIC_URL=https://your-tunnel.ngrok-free.app

# Ambient office background bed (applies to local + Twilio outbound playback)
AMBIENT_OFFICE_ENABLED=true
AMBIENT_OFFICE_GAIN=0.5
# Optional override; defaults to app/audio/assets/office_ambience_24k_mono.wav
AMBIENT_OFFICE_FILE=